<Window x:Class="PrintAndScan4Ukraine.PrintWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:local="clr-namespace:PrintAndScan4Ukraine"
        mc:Ignorable="d"
        Title="Print Labels"
        Height="340" Width="520"
        Background="{StaticResource PageBackground}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="/barcode.png">
    <Window.Resources>
        <!-- Validation rule -->
        <local:RangeValidationRule x:Key="RangeValidator"/>
        <!-- Keep your validation template -->
        <Style TargetType="TextBox">
            <Setter Property="Validation.ErrorTemplate">
                <Setter.Value>
                    <ControlTemplate>
                        <StackPanel>
                            <AdornedElementPlaceholder x:Name="textBox"/>
                            <TextBlock 
                                Foreground="Red"
                                FontSize="12"
                                Text="{Binding Path=AdornedElement.(Validation.Errors)[0].ErrorContent, 
                                               RelativeSource={RelativeSource AncestorType=Adorner}}" />
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <!-- MAIN CARD -->
        <Border Style="{StaticResource Card}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="25"
                Width="460"
                Margin="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Header -->
                    <RowDefinition Height="Auto"/>
                    <!-- Accent bar -->
                    <RowDefinition Height="Auto"/>
                    <!-- Printer -->
                    <RowDefinition Height="Auto"/>
                    <!-- Range -->
                    <RowDefinition Height="Auto"/>
                    <!-- Copies -->
                    <RowDefinition Height="Auto"/>
                    <!-- Buttons -->
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- HEADER -->
                <TextBlock Text="Print Labels"
                           Grid.ColumnSpan="4"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource HeaderText}"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 10"/>
                <!-- BLUE ACCENT BAR -->
                <Border Background="{StaticResource UA_Blue}"
                        Grid.Row="1"
                        Grid.ColumnSpan="4"
                        Height="6"
                        Width="140"
                        CornerRadius="3"
                        HorizontalAlignment="Center"
                        Margin="0 0 0 20"/>
                <!-- PRINTER SELECTION -->
                <TextBlock Text="List of Printers:"
                           Grid.Row="2" Grid.Column="0"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           FontWeight="Bold"
                           Foreground="{StaticResource HeaderText}"/>
                <ComboBox x:Name="CmbListOfPrinters"
                          Grid.Row="2" Grid.Column="1"
                          Grid.ColumnSpan="3"
                          ItemsSource="{Binding Printers}"
                          SelectedItem="{Binding SelectedPrinter}"
                          Width="210"
                          HorizontalAlignment="Left"
                          Margin="10 0 10 10"/>
                <!-- RANGE -->
                <TextBlock Text="Print labels from:"
                           Grid.Row="3" Grid.Column="0"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           FontWeight="Bold"
                           Foreground="{StaticResource HeaderText}"/>
                <TextBox x:Name="TxtFrom"
                         Grid.Row="3" Grid.Column="1"
                         Width="80"
                         Height="26"
                         VerticalContentAlignment="Center"
                         Text="{Binding Starting, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                         Margin="10 0 0 0"/>
                <TextBlock Text="to"
                           Grid.Row="3" Grid.Column="2"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource HeaderText}"/>
                <TextBox x:Name="TxtTo"
                         Grid.Row="3" Grid.Column="3"
                         Width="80"
                         Height="26"
                         VerticalContentAlignment="Center"
                         Text="{Binding Ending, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                <!-- COPIES -->
                <TextBlock Text="Copies of each label:"
                           Grid.Row="4" Grid.Column="0"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           FontWeight="Bold"
                           Foreground="{StaticResource HeaderText}"
                           Margin="0 10 0 0"/>
                <TextBox x:Name="TxtCopies"
                         Grid.Row="4" Grid.Column="1"
                         Width="80"
                         Height="26"
                         VerticalContentAlignment="Center"
                         Text="{Binding Copies}"
                         Margin="10 10 0 0"/>
                <!-- BUTTONS -->
                <StackPanel Grid.Row="5" Grid.ColumnSpan="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0 20 0 0">
                    <Button x:Name="BtnPrint"
                            Content="Print"
                            Command="{Binding PrintCommand}"
                            Style="{StaticResource SmallAccentButtonYellow}"
                            Width="90"
                            Margin="0 0 10 0"/>
                    <Button x:Name="BtnCancel"
                            Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource SmallAccentButton}"
                            Width="90"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
