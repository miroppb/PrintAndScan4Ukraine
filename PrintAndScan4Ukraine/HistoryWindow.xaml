<Window x:Class="PrintAndScan4Ukraine.HistoryWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:local="clr-namespace:PrintAndScan4Ukraine"
        mc:Ignorable="d"
        Title="Shipment History"
        Height="450" Width="650"
        Background="{StaticResource PageBackground}"
        WindowStartupLocation="CenterScreen"
        Icon="/barcode.png">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <!-- HEADER CARD -->
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Shipment History"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource HeaderText}"
                           Margin="0 0 0 10"/>
                <TextBlock Text="{Binding SenderName}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#1F2937"/>
            </StackPanel>
        </Border>
        <!-- LIST CARD -->
        <Border Grid.Row="1"
                Style="{StaticResource Card}"
                Margin="0 20 0 0">
            <ListView x:Name="LstItems"
                      ItemsSource="{Binding PreviousShipments}"
                      SelectedItem="{Binding SelectedShipment}"
                      BorderThickness="0"
                      Background="#FAFAFA">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Margin" Value="0 4"/>
                        <Setter Property="Padding" Value="8"/>
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="BorderBrush" Value="#D1D5DB"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6">
                                        <ContentPresenter Margin="4"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource UA_Blue}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource UA_Yellow}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding Recipient_Name}"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Foreground="#1F2937"/>
                            <TextBlock Text="{Binding Recipient_Address}"
                                       Grid.Row="1"
                                       Foreground="#374151"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</Window>