<Window x:Class="PrintAndScan4Ukraine.EditPreviousShipmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Tr 'PAS4U.MainMenu.PreviousShipment.EditPreviousShipment', DefaultText='Edit Previous Shipment'}"
        Height="520" Width="900"
        Background="{StaticResource PageBackground}"
        WindowStartupLocation="CenterScreen"
        Icon="/barcode.png">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <!-- Exports -->
            <ColumnDefinition Width="3*"/>
            <!-- Preview -->
        </Grid.ColumnDefinitions>

        <!-- LEFT CARD: EXPORT LIST -->
        <Border Style="{StaticResource Card}"
                Padding="20"
                Margin="0 0 15 0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Text="{Tr 'PAS4U.MainMenu.PreviousShipment.PreviousShipments', DefaultText='Previous Shipments'}"
                           FontSize="20"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Foreground="{StaticResource HeaderText}"/>

                <!-- Accent bar -->
                <Border Grid.Row="1"
                        Background="{StaticResource UA_Blue}"
                        Height="4"
                        Width="140"
                        CornerRadius="2"
                        Margin="0 8 0 12"/>

                <!-- Export list -->
                <ListView Grid.Row="2"
                          ItemsSource="{Binding Exports}"
                          SelectedItem="{Binding SelectedExport}"
                          Margin="0 0 0 10">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4">
                                <TextBlock Text="{Binding Filename}"
                                           FontWeight="Bold"/>
                                <TextBlock Text="{Binding Datetime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                           FontSize="12"
                                           Foreground="#6B7280"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

            </Grid>
        </Border>

        <!-- RIGHT CARD: PREVIEW -->
        <Border Grid.Column="1"
                Style="{StaticResource Card}"
                Padding="20"
                Margin="15 0 0 0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Header -->
                    <RowDefinition Height="Auto"/>
                    <!-- Accent -->
                    <RowDefinition Height="Auto"/>
                    <!-- Count -->
                    <RowDefinition Height="*"/>
                    <!-- List -->
                    <RowDefinition Height="Auto"/>
                    <!-- Buttons -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Text="{Tr 'PAS4U.MainMenu.PreviousShipment.ShipmentPreview', DefaultText='Shipment Preview'}"
                           FontSize="20"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Foreground="{StaticResource HeaderText}"/>

                <!-- Accent bar -->
                <Border Grid.Row="1"
                        Background="{StaticResource UA_Yellow}"
                        Height="4"
                        Width="140"
                        CornerRadius="2"
                        Margin="0 8 0 12"/>

                <!-- Count -->
                <TextBlock Grid.Row="2"
                           Text="{Binding PreviewCount, StringFormat='Package Count: {0}'}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#374151"
                           Margin="0 0 0 10"/>

                <!-- Preview list -->
                <ListView Grid.Row="3"
                          ItemsSource="{Binding PreviewPackageIds}"
                          Margin="0 0 0 10">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="14"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Buttons -->
                <StackPanel Grid.Row="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button Content="{Tr 'PAS4U.MainMenu.PreviousShipment.LoadShipment', DefaultText='Load Shipment'}"
                            Width="150"
                            Margin="0 0 10 0"
                            Style="{StaticResource SmallAccentButtonYellow}"
                            Command="{Binding LoadShipmentCommand}"/>

                    <Button Content="{Tr 'PAS4U.MainMenu.PreviousShipment.Cancel', DefaultText='Cancel'}"
                            Width="90"
                            Style="{StaticResource SmallAccentButton}"
                            Command="{Binding CancelCommand}"/>
                </StackPanel>

            </Grid>
        </Border>

    </Grid>
</Window>
