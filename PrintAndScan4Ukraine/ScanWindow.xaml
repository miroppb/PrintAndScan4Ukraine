<Window x:Class="PrintAndScan4Ukraine.ScanWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:local="clr-namespace:PrintAndScan4Ukraine.Converter"
	xmlns:local2="clr-namespace:PrintAndScan4Ukraine"
        mc:Ignorable="d"
        Title="{Binding Header}"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PageBackground}"
        Icon="/barcode.png">
    <Window.Resources>
        <local:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter" />
        <local:BoolToGridRowHeightConverter x:Key="BoolToGridRowHeightConverter" />
        <local:StatusToTextConverter x:Key="StatusToTextConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <Style TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="ToolTip"
                            Value="{Binding (Validation.Errors)[0].ErrorContent, RelativeSource={RelativeSource Self}}" />
                    <Setter Property="BorderBrush" Value="Red" />
                    <Setter Property="BorderThickness" Value="2" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Menu -->
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition/>
            <!-- Main content -->
            <RowDefinition Height="Auto"/>
            <!-- Footer -->
        </Grid.RowDefinitions>
        <!-- MENU BAR -->
        <DockPanel Grid.Row="0">
            <Menu DockPanel.Dock="Top">
                <MenuItem Header="{Tr 'PAS4U.MainMenu.FileMenuItem.Header', DefaultText='_File'}">
                    <MenuItem x:Name="MnuSaveAll" Header="{Tr 'PAS4U.MainMenu.FileMenuItem.SaveAllItem.Header', DefaultText='_Save All'}" Command="{Binding SaveAllCommand}" />
                    <MenuItem x:Name="MnuNew" Header="{Tr 'PAS4U.MainMenu.FileMenuItem.ScanNewItem.Header', DefaultText='Scan _New'}" Command="{Binding AddNewCommand}"
                              Visibility="{Binding AccessToShip, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <MenuItem x:Name="MnuShipped" Header="{Tr 'PAS4U.MainMenu.FileMenuItem.ScanShippedItem.Header', DefaultText='Scan S_hipped'}" Command="{Binding ShipCommand}"
                              Visibility="{Binding AccessToShip, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <MenuItem x:Name="MnuArrive" Header="{Tr 'PAS4U.MainMenu.FileMenuItem.ScanArriveItem.Header', DefaultText='Scan _Arrived'}" Command="{Binding ArriveCommand}"
                              Visibility="{Binding AccessToArrive, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <MenuItem x:Name="MnuDeliver" Header="{Tr 'PAS4U.MainMenu.FileMenuItem.ScanDeliverItem.Header', DefaultText='Scan _Delivered'}" Command="{Binding DeliverCommand}"
                              Visibility="{Binding AccessToDeliver, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <MenuItem x:Name="MnuEditPackageId" Header="{Tr 'PAS4U.MainMenu.FileMenuItem.EditPackageId.Header', DefaultText='Edit _Package IDs'}" Command="{Binding EditPackageIDCommand}"
                              Visibility="{Binding CanEditPackageID, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                              IsChecked="{Binding IsEditingPackageID, UpdateSourceTrigger=PropertyChanged}" />
                </MenuItem>
                <MenuItem Header="{Tr 'PAS4U.MainMenu.ExportMenuItem.Header', DefaultText='_Export'}">
                    <MenuItem x:Name="MnuExport" Header="{Tr 'PAS4U.MainMenu.ExportMenuItem.ExportExcel.Header', DefaultText='E_xport to Excel'}" Command="{Binding ExportCommand}"
                              Visibility="{Binding AccessToExport, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </MenuItem>
                <MenuItem Header="{Tr 'PAS4U.MainMenu.ToolsMenu.Header', DefaultText='_Tools'}">
                    <MenuItem x:Name="MnuSearch" Header="{Tr 'PAS4U.MainMenu.ToolsMenu.Search', DefaultText='S_earch'}" Command="{Binding ShowSearchCommand}" />
                    <MenuItem x:Name="MnuFindRepeating" Header="{Tr 'PAS4U.MainMenu.ToolsMenu.FindRepeating', DefaultText='Find Repeating Recipients'}" Command="{Binding ShowFindRepeatingRecipientsCommand}"
                              Visibility="{Binding AccessToShip, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <MenuItem x:Name="MnuEditPreviousShipment" Header="{Tr 'PAS4U.MainMenu.ToolsMenu.EditPreviousShipment', DefaultText='Edit Previous Shipment'}" Command="{Binding ShowEditPreviousShipmentCommand}"
                              Visibility="{Binding AccessToShip, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <MenuItem x:Name="MnuCheckUpdate" Header="{Tr 'PAS4U.MainMenu.ToolsMenu.Update', DefaultText='_Update'}" Command="{Binding ShowCheckUpdateCommand}" />
                </MenuItem>
                <MenuItem Header="{Tr 'PAS4U.MainMenu.Language', DefaultText='_Language'}">
                    <MenuItem x:Name="MnuEnglish" Header="{Tr 'LanguageName', DefaultText='_English', LanguageId='en'}" Click="MnuEnglish_Click" />
                    <MenuItem x:Name="MnuRussian" Header="{Tr 'LanguageName', DefaultText='_Russian', LanguageId='ru'}" Click="MnuRussian_Click" />
                </MenuItem>
            </Menu>
        </DockPanel>
        <!-- HEADER -->
        <Grid Grid.Row="1" Margin="20 10 20 10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Print and Scan 4 Ukraine"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{StaticResource HeaderText}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding LastSaved}"
                       FontSize="14"
                       Foreground="#4B5563"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Right"/>
        </Grid>
        <!-- MAIN DASHBOARD -->
        <Grid Grid.Row="2" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <!-- Packages -->
                <ColumnDefinition Width="6*"/>
                <!-- Sender/Receiver -->
                <ColumnDefinition Width="2.5*"/>
                <!-- Contents -->
            </Grid.ColumnDefinitions>
            <!-- LEFT CARD: SEARCH + PACKAGE LIST -->
            <Border Style="{StaticResource Card}"
                    Margin="0 0 15 0"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Title -->
                        <RowDefinition Height="Auto"/>
                        <!-- Accent -->
                        <RowDefinition Height="Auto"/>
                        <!-- Search -->
                        <RowDefinition/>
                        <!-- List -->
                        <RowDefinition Height="Auto"/>
                        <!-- Total -->
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Tr 'PAS4U.MainWindow.PackageList', DefaultText='Packages'}"
                               FontSize="18"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               Foreground="{StaticResource HeaderText}"
                               Margin="0 0 0 6"/>
                    <Border Grid.Row="1"
                            Background="{StaticResource UA_Blue}"
                            Height="4"
                            Width="80"
                            CornerRadius="2"
                            Margin="0 0 0 10"/>
                    <!-- Search bar -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="0 0 0 8"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Tr 'PAS4U.MainWindow.Search', DefaultText='Search'}"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   Margin="0 0 6 0"
                                   Foreground="#111827"/>
                        <TextBox x:Name="TxtSearch"
                                 Width="105"
                                 Height="28"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Type a Package ID to filter the list"/>
                        <Button Content="{Tr 'PAS4U.MainWindow.Clear', DefaultText='Clear'}"
                                Height="28"
                                Margin="6 0 0 0"
                                Command="{Binding ClearSearchCommand}"
                                Style="{StaticResource SmallAccentButton}"/>
                    </StackPanel>
                    <!-- Package list -->
                    <ListView x:Name="LstUPCAndNames"
                              Grid.Row="3"
                              Margin="0 0 0 6"
                              ItemsSource="{Binding FilteredPackages}"
                              SelectedItem="{Binding SelectedPackage, Mode=TwoWay}"
                              DisplayMemberPath="PackageId"
                              SelectionMode="Single"
                              Visibility="{Binding AccessToSeePackages, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"></ListView>
                    <!-- Total -->
                    <TextBlock Grid.Row="4"
                               Text="{Tr 'PAS4U.MainWindow.Total', {Binding Packages.Count}, DefaultText='Total'}"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               Foreground="#4B5563"/>
                </Grid>
            </Border>
            <!-- MIDDLE CARD: CLEAN, FIXED, NO OVERLAPS -->
            <Border Grid.Column="1"
        Style="{StaticResource Card}"
        Padding="20"
        Margin="8 0 8 0">

                <Grid>

                    <!-- ROW DEFINITIONS -->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Header -->
                        <RowDefinition Height="Auto"/>
                        <!-- Accent -->
                        <RowDefinition Height="Auto"/>
                        <!-- Package ID -->
                        <RowDefinition Height="Auto"/>
                        <!-- Sender Name -->
                        <RowDefinition Height="Auto"/>
                        <!-- Sender Address -->
                        <RowDefinition Height="Auto"/>
                        <!-- Sender Phone -->
                        <RowDefinition Height="20"/>
                        <!-- Divider -->
                        <RowDefinition Height="Auto"/>
                        <!-- Receiver Name -->
                        <RowDefinition Height="Auto"/>
                        <!-- Receiver Address -->
                        <RowDefinition Height="Auto"/>
                        <!-- Receiver Phone -->
                        <RowDefinition Height="*"/>
                        <!-- Spacer -->
                    </Grid.RowDefinitions>

                    <!-- COLUMN DEFINITIONS -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <!-- Labels -->
                        <ColumnDefinition Width="*"/>
                        <!-- Inputs -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Status / Buttons -->
                    </Grid.ColumnDefinitions>

                    <!-- HEADER -->
                    <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                   Text="{Tr 'PAS4U.MainWindow.Details', DefaultText='Details'}"
                   FontSize="20"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Foreground="{StaticResource HeaderText}"/>

                    <!-- ACCENT BAR -->
                    <Border Grid.Row="1" Grid.ColumnSpan="3"
                Background="{StaticResource UA_Yellow}"
                Height="4"
                Width="100"
                HorizontalAlignment="Center"
                CornerRadius="2"
                Margin="0 8 0 16"/>

                    <!-- PACKAGE ID LABEL -->
                    <TextBlock Grid.Row="2" Grid.Column="0"
                   Text="{Tr 'PAS4U.MainWindow.PackageId', DefaultText='Package ID'}"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   Foreground="{StaticResource HeaderText}"/>

                    <!-- PACKAGE ID VIEW MODE -->
                    <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                   x:Name="TxtPackageIdView"
                   Text="{Binding ElementName=LstUPCAndNames, Path=SelectedItem.PackageId}"
                   FontSize="20"
                   VerticalAlignment="Center"
                   Visibility="{Binding IsEditingPackageID, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>

                    <!-- PACKAGE ID EDIT MODE -->
                    <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                 x:Name="TxtPackageIdEdit"
                 FontSize="20"
                 Width="200"
                             HorizontalAlignment="Left"
                 VerticalContentAlignment="Center"
                 Visibility="{Binding IsEditingPackageID, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBox.Text>
                            <Binding ElementName="LstUPCAndNames"
                         Path="SelectedItem.NewPackageId"
                         Mode="TwoWay"
                         UpdateSourceTrigger="PropertyChanged"
                         ValidatesOnNotifyDataErrors="True"
                         NotifyOnValidationError="True"/>
                        </TextBox.Text>
                    </TextBox>

                    <!-- PACKAGE ID VALIDATION -->
                    <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                   Foreground="Red"
                   FontSize="12"
                   Margin="0 28 0 0"
                   Visibility="{Binding (Validation.HasError), ElementName=TxtPackageIdEdit, Converter={StaticResource BooleanToVisibilityConverter}}"
                   Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=TxtPackageIdEdit}"/>

                    <!-- LAST STATUS -->
                    <TextBlock Grid.Row="2" Grid.Column="2"
                   x:Name="TxtLastStatus"
                   Text="{Tr 'PAS4U.MainWindow.LastStatus', {Binding SelectedPackageLastStatus.Status, Converter={StaticResource StatusToTextConverter}}, {Binding SelectedPackageLastStatus.CreatedDate}}"
                   VerticalAlignment="Center"
                   Margin="10 0 0 0"
                   TextAlignment="Right"
                   Visibility="{Binding IsSelectedPackageShowing}"/>

                    <!-- SENDER NAME LABEL -->
                    <TextBlock Grid.Row="3" Grid.Column="0"
                   Text="{Tr 'PAS4U.MainWindow.SenderName', DefaultText='Sender Name'}"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   Foreground="{StaticResource HeaderText}"/>

                    <!-- SENDER NAME + HISTORY BUTTON -->
                    <StackPanel Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="0 4 0 4">

                        <TextBox x:Name="TxtSenderName"
                     Width="260"
                     Height="28"
                     VerticalContentAlignment="Center"
                     Text="{Binding ElementName=LstUPCAndNames, Path=SelectedItem.Sender_Name, Mode=TwoWay}"
                     IsReadOnly="{Binding AccessToEditSender}"/>

                        <Button Content="{Tr 'PAS4U.MainWindow.ShowHistoryButton', DefaultText='History'}"
                    Height="26"
                    Margin="10 0 0 0"
                    Command="{Binding ShowHistoryCommand}"
                    Style="{StaticResource SmallAccentButton}"/>
                    </StackPanel>

                    <!-- SENDER ADDRESS -->
                    <TextBlock Grid.Row="4" Grid.Column="0"
                   Text="{Tr 'PAS4U.MainWindow.SenderAddress', DefaultText='Sender Address'}"
                   FontWeight="Bold"
                   Foreground="{StaticResource HeaderText}"/>

                    <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                 x:Name="TxtSenderAddress"
                 Text="{Binding ElementName=LstUPCAndNames, Path=SelectedItem.Sender_Address, Mode=TwoWay}"
                 IsReadOnly="{Binding AccessToEditSender}"
                 Height="70"
                 VerticalContentAlignment="Top"
                 AcceptsReturn="True"
                 Padding="4"/>

                    <!-- SENDER PHONE -->
                    <TextBlock Grid.Row="5" Grid.Column="0"
                   Text="{Tr 'PAS4U.MainWindow.SenderPhone', DefaultText='Sender Phone'}"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   Foreground="{StaticResource HeaderText}"/>

                    <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2"
                 x:Name="TxtSenderPhone"
                 Text="{Binding ElementName=LstUPCAndNames, Path=SelectedItem.Sender_Phone, Mode=TwoWay}"
                 IsReadOnly="{Binding AccessToEditSender}"
                 Height="28"
                 VerticalContentAlignment="Center"/>

                    <!-- DIVIDER -->
                    <Rectangle Grid.Row="6" Grid.ColumnSpan="3"
                   Height="1"
                   Fill="{StaticResource UA_Yellow}"
                   Margin="0 10 0 10"/>

                    <!-- RECEIVER NAME -->
                    <TextBlock Grid.Row="7" Grid.Column="0"
                   Text="{Tr 'PAS4U.MainWindow.ReceiverName', DefaultText='Receiver Name'}"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   Foreground="{StaticResource HeaderText}"/>

                    <TextBox Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2"
                 x:Name="TxtRecipientFName"
                 Text="{Binding ElementName=LstUPCAndNames, Path=SelectedItem.Recipient_Name, Mode=TwoWay}"
                 IsReadOnly="{Binding AccessToEditReceipient}"
                 Height="28"
                 VerticalContentAlignment="Center"/>

                    <!-- RECEIVER ADDRESS -->
                    <TextBlock Grid.Row="8" Grid.Column="0"
                   Text="{Tr 'PAS4U.MainWindow.ReceiverAddress', DefaultText='Receiver Address'}"
                   FontWeight="Bold"
                   Foreground="{StaticResource HeaderText}"/>

                    <TextBox Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2"
                 x:Name="TxtRecipientAddress"
                 Text="{Binding ElementName=LstUPCAndNames, Path=SelectedItem.Recipient_Address, Mode=TwoWay}"
                 IsReadOnly="{Binding AccessToEditReceipient}"
                 Height="70"
                 VerticalContentAlignment="Top"
                 AcceptsReturn="True"
                 Padding="4"/>

                    <!-- RECEIVER PHONE -->
                    <TextBlock Grid.Row="9" Grid.Column="0"
                   Text="{Tr 'PAS4U.MainWindow.ReceiverPhone', DefaultText='Receiver Phone'}"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   Foreground="{StaticResource HeaderText}"/>

                    <TextBox Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="2"
                 x:Name="TxtRecipientPhone"
                 Text="{Binding ElementName=LstUPCAndNames, Path=SelectedItem.Recipient_Phone, Mode=TwoWay}"
                 IsReadOnly="{Binding AccessToEditReceipient}"
                 Height="28"
                 VerticalContentAlignment="Center"/>

                </Grid>
            </Border>


            <!-- RIGHT CARD: CONTENTS / VALUE / WEIGHT / DELIVERY -->
            <Border Grid.Column="2"
                    Style="{StaticResource Card}"
                    Margin="15 0 0 0"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Header -->
                        <RowDefinition Height="Auto"/>
                        <!-- Accent -->
                        <RowDefinition Height="*"/>
                        <!-- Contents grid -->
                        <RowDefinition Height="Auto"/>
                        <!-- Value -->
                        <RowDefinition Height="Auto"/>
                        <!-- Weight -->
                        <RowDefinition Height="Auto"/>
                        <!-- Delivery -->
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Tr 'PAS4U.MainWindow.Contents', DefaultText='Contents / Amount'}"
                               Grid.Row="0" Grid.ColumnSpan="2"
                               FontSize="18"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource HeaderText}"
                               Margin="0 0 0 6"/>
                    <Border Grid.Row="1" Grid.ColumnSpan="2"
                            Background="{StaticResource UA_Blue}"
                            Height="4"
                            Width="100"
                            CornerRadius="2"
                            Margin="0 0 0 10"/>
                    <DataGrid x:Name="LstContents"
                              Grid.Row="2" Grid.ColumnSpan="2"
                              Height="220"
                              ItemsSource="{Binding ElementName=LstUPCAndNames, Path=SelectedItem.Recipient_Contents, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="True"
                              CanUserSortColumns="False"
                              CanUserReorderColumns="False"
                              CanUserResizeRows="False"
                              CanUserDeleteRows="True"
                              IsReadOnly="{Binding AccessToEditReceipient}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{Tr 'PAS4U.MainWindow.ContentsName', DefaultText='Name'}"
                                                Width="*"
                                                Binding="{Binding Name}"/>
                            <DataGridTextColumn Header="{Tr 'PAS4U.MainWindow.ContentsAmount', DefaultText='Amount'}"
                                                Width="80"
                                                Binding="{Binding Amount}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Grid.Row="3" Grid.Column="0"
                               Text="{Tr 'PAS4U.MainWindow.Value', DefaultText='Value'}"
                               FontWeight="Bold"
                               Foreground="{StaticResource HeaderText}"
                               Margin="0 6 0 0"/>
                    <TextBox x:Name="TxtCost"
                             Grid.Row="3" Grid.Column="1"
                             Text="{Binding ElementName=LstUPCAndNames, Path=SelectedItem.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="{Binding AccessToEditReceipient}"
                             Height="26"
                             Margin="6 4 0 0"/>
                    <TextBlock Grid.Row="4" Grid.Column="0"
                               Text="{Tr 'PAS4U.MainWindow.Weight', DefaultText='Weight'}"
                               FontWeight="Bold"
                               Foreground="{StaticResource HeaderText}"
                               Margin="0 4 0 0"/>
                    <TextBox x:Name="TxtWeight"
                             Grid.Row="4" Grid.Column="1"
                             Text="{Binding ElementName=LstUPCAndNames, Path=SelectedItem.Weight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="{Binding AccessToEditReceipient}"
                             Height="26"
                             Margin="6 4 0 0"/>
                    <TextBlock Grid.Row="5" Grid.Column="0"
                               Text="{Tr 'PAS4U.MainWindow.Delivery', DefaultText='Delivery'}"
                               FontWeight="Bold"
                               Foreground="{StaticResource HeaderText}"
                               Margin="0 6 0 0"/>
                    <CheckBox x:Name="ChkDelivery"
                              Grid.Row="5" Grid.Column="1"
                              IsChecked="{Binding ElementName=LstUPCAndNames, Path=SelectedItem.Delivery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEnabled="{Binding AccessToEditReceipient, Converter={StaticResource InverseBooleanConverter}}"
                              HorizontalAlignment="Left"
                              Margin="6 4 0 0">
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="1.4" ScaleY="1.4"/>
                        </CheckBox.LayoutTransform>
                    </CheckBox>
                </Grid>
            </Border>
        </Grid>
        <!-- FOOTER CARD: SAVE / OFFLINE / TOTAL -->
        <Border Grid.Row="3"
                Style="{StaticResource Card}"
                Margin="20 0 20 20"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnSave"
                        Content="{Tr 'PAS4U.MainWindow.SaveButton', DefaultText='Save'}"
                        Width="110"
                        Height="30"
                        FontSize="16"
                        FontWeight="Bold"
                        HorizontalAlignment="Left"
                        Command="{Binding SaveCommand, Mode=OneTime}"
                        Style="{StaticResource SmallAccentButtonYellow}"/>
                <TextBlock Grid.Column="1"
                           Text="{Tr 'PAS4U.MainWindow.Offline', DefaultText='We`re Offline'}"
                           Margin="16 0 0 0"
                           FontSize="16"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Visibility="{Binding IsOnline, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"
                           Foreground="Red"/>
                <Button x:Name="BtnCompletePrevious"
                            Content="{Tr 'PAS4U.MainWindow.CompletePreviousButton', DefaultText='Complete Previous'}"
                        Grid.Column="2"
                            Height="30"
                            FontSize="16"
                            FontWeight="Bold"
                            Visibility="{Binding EditingPreviousShipment, Converter={StaticResource BooleanToVisibilityConverter}}"
                            HorizontalAlignment="Left"
                            Command="{Binding CompletePreviousCommand, Mode=OneTime}"
                            Style="{StaticResource SmallAccentButtonYellow}"/>
                <TextBlock x:Name="TxtTotal"
                           Grid.Column="3"
                           Text="{Tr 'PAS4U.MainWindow.Total', {Binding SelectedPackage.Total}, DefaultText='Total'}"
                           FontSize="16"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsSelectedPackageShowing}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
