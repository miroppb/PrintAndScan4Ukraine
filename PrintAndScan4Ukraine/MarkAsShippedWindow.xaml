<Window x:Class="PrintAndScan4Ukraine.MarkAsShippedWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:local="clr-namespace:PrintAndScan4Ukraine"
        mc:Ignorable="d"
        Title="{Tr 'PAS4U.ScanShippedWindow.Title', DefaultText='Scan Shipped Window'}"
        Height="400" Width="500"
        Background="{StaticResource PageBackground}"
        WindowStartupLocation="CenterScreen"
        Icon="/barcode.png">
    <Window.Resources>
        <!-- Flash animation for scanned codes -->
        <Storyboard x:Key="FlashAnimation">
            <ColorAnimation
                Storyboard.TargetName="FlashBorder"
                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                From="#A7D8FF"
                To="Transparent"
                Duration="0:0:0.25"
                AutoReverse="False"/>
        </Storyboard>
    </Window.Resources>
    <!-- OUTER GRID -->
    <Grid>
        <!-- MAIN CARD -->
        <Border Style="{StaticResource Card}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="25"
                Width="420"
                Margin="20">
            <StackPanel HorizontalAlignment="Center">
                <!-- TOP TEXT -->
                <TextBlock Text="{Tr 'PAS4U.ScanShippedWindow.TopText', DefaultText='Scan barcodes that were shipped'}"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource HeaderText}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0 0 0 10"/>
                <!-- BLUE ACCENT BAR -->
                <Border Background="{StaticResource UA_Blue}"
                        Height="6"
                        Width="140"
                        CornerRadius="3"
                        Margin="0 10 0 20"/>
                <!-- SCANNED CODES -->
                <Border x:Name="FlashBorder"
                        CornerRadius="6"
                        Padding="10"
                        HorizontalAlignment="Center"
                        Margin="0 0 0 20">
                    <Border.Background>
                        <SolidColorBrush Color="Transparent"/>
                    </Border.Background>
                    <TextBlock x:Name="LblCodes"
                               Text="{Binding CodesScanned}"
                               FontSize="16"
                               Foreground="#374151"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                </Border>
                <!-- DONE BUTTON -->
                <Button x:Name="BtnDone"
                        Content="{Tr 'PAS4U.ScanShippedWindow.DoneText', DefaultText='Done'}"
                        Command="{Binding DoneCommand}"
                        CommandParameter="Shipped"
                        IsEnabled="{Binding DoneButtonEnabled}"
                        Style="{StaticResource AccentButtonYellow}"
                        Padding="12"
                        FontSize="20"
                        HorizontalAlignment="Center"
                        Width="160"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>