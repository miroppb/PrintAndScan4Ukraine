<Window x:Class="PrintAndScan4Ukraine.ReportSelection"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:local="clr-namespace:PrintAndScan4Ukraine"
	xmlns:gif="http://wpfanimatedgif.codeplex.com"
        mc:Ignorable="d"
        Title="Report Selection"
        Height="390" Width="480"
        Background="{StaticResource PageBackground}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow">
    <Grid>
        <!-- MAIN CARD -->
        <Border Style="{StaticResource Card}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="25"
                Width="420"
                Margin="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- HEADER -->
                <TextBlock Text="Report Options"
                           Grid.ColumnSpan="2"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource HeaderText}"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 10"/>
                <!-- BLUE ACCENT BAR -->
                <Border Background="{StaticResource UA_Blue}"
                        Grid.Row="1"
                        Grid.ColumnSpan="2"
                        Height="6"
                        Width="140"
                        CornerRadius="3"
                        HorizontalAlignment="Center"
                        Margin="0 0 0 20"/>
                <!-- START DATE -->
                <TextBlock Text="{Tr 'PAS4U.ReportWindow.StartDate', DefaultText='Start Date:'}"
                           Grid.Row="2" Grid.Column="0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Foreground="{StaticResource HeaderText}"/>
                <DatePicker Grid.Row="2" Grid.Column="1"
                            SelectedDate="{Binding ExportStartDate}"
                            Width="160"
                            Margin="10 0 0 0"/>
                <!-- END DATE -->
                <TextBlock Text="{Tr 'PAS4U.ReportWindow.EndDate', DefaultText='End Date:'}"
                           Grid.Row="3" Grid.Column="0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Foreground="{StaticResource HeaderText}"/>
                <DatePicker Grid.Row="3" Grid.Column="1"
                            SelectedDate="{Binding ExportEndDate}"
                            Width="160"
                            Margin="10 0 0 0"/>
                <!-- DATE RANGE OPTIONS -->
                <TextBlock Text="{Tr 'PAS4U.ReportWindow.Dates', DefaultText='Dates:'}"
                           Grid.Row="4" Grid.Column="0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Foreground="{StaticResource HeaderText}"/>
                <StackPanel Grid.Row="4" Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="10 0 0 0">
                    <RadioButton GroupName="ReportDates"
                                 Content="{Tr 'PAS4U.ReportWindow.All', DefaultText='All'}"
                                 Command="{Binding RadioDateChecked}"
                                 CommandParameter="All"
                                 Margin="0 0 20 0"/>
                    <RadioButton GroupName="ReportDates"
                                 Content="{Tr 'PAS4U.ReportWindow.Dates', DefaultText='Dates'}"
                                 Command="{Binding RadioDateChecked}"
                                 CommandParameter="Dates"
                                 IsChecked="True"/>
                </StackPanel>
                <!-- STATUS OPTIONS -->
                <TextBlock Text="{Tr 'PAS4U.ReportWindow.LastStatus', DefaultText='Last Status:'}"
                           Grid.Row="5" Grid.Column="0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Foreground="{StaticResource HeaderText}"/>
                <StackPanel Grid.Row="5" Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="10 0 0 0">
                    <RadioButton GroupName="ReportStatus"
                                 Content="{Tr 'PAS4U.ReportWindow.Scanned', DefaultText='Scanned'}"
                                 Command="{Binding RadioStatusChecked}"
                                 CommandParameter="Scanned"
                                 Margin="0 0 20 0"/>
                    <RadioButton GroupName="ReportStatus"
                                 Content="{Tr 'PAS4U.ReportWindow.Shipped', DefaultText='Shipped'}"
                                 Command="{Binding RadioStatusChecked}"
                                 CommandParameter="Shipped"
                                 IsChecked="True"/>
                </StackPanel>
                <StackPanel Grid.Row="6" Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="10 0 0 0">
                    <RadioButton GroupName="ReportStatus"
                                 Content="{Tr 'PAS4U.ReportWindow.Arrived', DefaultText='Arrived'}"
                                 Command="{Binding RadioStatusChecked}"
                                 CommandParameter="Arrived"
                                 Margin="0 0 20 0"/>
                    <RadioButton GroupName="ReportStatus"
                                 Content="{Tr 'PAS4U.ReportWindow.Delivered', DefaultText='Delivered'}"
                                 Command="{Binding RadioStatusChecked}"
                                 CommandParameter="Delivered"/>
                </StackPanel>
                <!-- EXPORT + SPINNER + NOTE -->
                <StackPanel Grid.Row="7"
                    Grid.ColumnSpan="2"
                    Orientation="Vertical"
                    HorizontalAlignment="Center"
                    Margin="0 20 0 0">
                    <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                        <Button Content="{Tr 'PAS4U.ReportWindow.Export', DefaultText='Export'}"
                            Command="{Binding GenerateReportCommand}"
                            IsEnabled="{Binding ExportButtonEnabled}"
                            Style="{StaticResource AccentButton}"
                            Width="120"/>
                        <Image gif:ImageBehavior.AnimatedSource="images/loading-loading-forever.gif"
                           Height="22" Width="22"
                           Margin="10 0 0 0"
                           Visibility="{Binding SpinnerVisible}"/>
                    </StackPanel>
                    <TextBlock Text="{Tr 'PAS4U.ReportWindow.Note', DefaultText='Might take a few seconds to generate'}"
                       TextAlignment="Center"
                       FontSize="10"
                       Foreground="#374151"
                       Margin="0 6 0 0"
                       Visibility="{Binding SpinnerVisible}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
