<Window x:Class="PrintAndScan4Ukraine.ScanNewWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:local="clr-namespace:PrintAndScan4Ukraine"
        mc:Ignorable="d"
        Title="{Tr 'PAS4U.ScanNewWindow.Title', DefaultText='Scan New Window'}"
        Height="440" Width="550"
        Background="{StaticResource PageBackground}"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Icon="/barcode.png">
    <Window.Resources>
        <!-- Flash animation for scanned codes -->
        <Storyboard x:Key="FlashAnimation">
            <ColorAnimation
                Storyboard.TargetName="FlashBorder"
                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                From="#A7D8FF"
                To="Transparent"
                Duration="0:0:0.25"
                AutoReverse="False"/>
        </Storyboard>
    </Window.Resources>
    <Grid>
        <!-- MAIN CARD -->
        <Border Style="{StaticResource Card}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="25"
                Width="480"
                Margin="20">
            <StackPanel HorizontalAlignment="Center">
                <!-- ADD MULTIPLE BUTTON -->
                <Button Content="{Binding AddMultipleButton, FallbackValue='Add Multiple'}"
                        Command="{Binding AddMultipleCommand}"
                        Visibility="{Binding AddMultipleVisible}"
                        Style="{StaticResource AccentButton}"
                        HorizontalAlignment="Center"
                        Width="180"
                        Margin="0 0 0 20"/>
                <!-- TOP TEXT -->
                <TextBlock Text="{Binding AddMultipleText, FallbackValue='Scan barcode to add...'}"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource HeaderText}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0 0 0 10"/>
                <!-- BLUE ACCENT BAR -->
                <Border Background="{StaticResource UA_Blue}"
                        Height="6"
                        Width="140"
                        CornerRadius="3"
                        Margin="0 10 0 20"/>
                <!-- SCANNED BARCODE -->
                <Border x:Name="FlashBorder"
                        CornerRadius="6"
                        Padding="10"
                        HorizontalAlignment="Center"
                        Margin="0 0 0 20">
                    <Border.Background>
                        <SolidColorBrush Color="Transparent"/>
                    </Border.Background>
                    <TextBlock Text="{Binding BarCode, FallbackValue='CV0000000US'}"
                               FontSize="20"
                               Foreground="#374151"
                               TextAlignment="Center"/>
                </Border>
                <!-- BOTTOM TEXT -->
                <TextBlock Text="{Tr 'PAS4U.ScanNewWindow.BottomText', DefaultText='Or press Enter to close'}"
                           FontSize="18"
                           Foreground="#374151"
                           TextAlignment="Center"
                           Margin="0 10 0 0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>