<Window x:Class="PrintAndScan4Ukraine.SearchSelectionWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:local="clr-namespace:PrintAndScan4Ukraine"
        mc:Ignorable="d"
        Title="{Tr 'PAS4U.MainMenu.SearchSelectionWindow.Title', DefaultText='Search Selection'}"
        Height="320" Width="380"
        Background="{StaticResource PageBackground}"
        WindowStartupLocation="CenterScreen"
        Icon="/barcode.png">
    <Grid FocusManager.FocusedElement="{Binding ElementName=TxtSearch}">
        <!-- MAIN CARD -->
        <Border Style="{StaticResource Card}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="25"
                Width="320"
                Margin="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Header -->
                    <RowDefinition Height="Auto"/>
                    <!-- Accent bar -->
                    <RowDefinition Height="Auto"/>
                    <!-- Search param -->
                    <RowDefinition Height="Auto"/>
                    <!-- Radio buttons -->
                    <RowDefinition Height="Auto"/>
                    <!-- Archive -->
                    <RowDefinition Height="Auto"/>
                    <!-- Button -->
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- HEADER -->
                <TextBlock Text="Search Options"
                           Grid.ColumnSpan="2"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{StaticResource HeaderText}"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 10"/>
                <!-- BLUE ACCENT BAR -->
                <Border Background="{StaticResource UA_Blue}"
                        Grid.Row="1"
                        Grid.ColumnSpan="2"
                        Height="6"
                        Width="120"
                        CornerRadius="3"
                        HorizontalAlignment="Center"
                        Margin="0 0 0 20"/>
                <!-- SEARCH PARAMETER -->
                <TextBlock Text="Search Parameter:"
                           Grid.Row="2" Grid.Column="0"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           FontWeight="Bold"
                           Foreground="{StaticResource HeaderText}"/>
                <TextBox x:Name="TxtSearch"
                         Grid.Row="2" Grid.Column="1"
                         Text="{Binding SearchParam, UpdateSourceTrigger=PropertyChanged}"
                         Margin="10 0 0 10"
                         VerticalContentAlignment="Center"/>
                <!-- RADIO BUTTONS -->
                <StackPanel Grid.Row="3" Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0 5 0 5">
                    <RadioButton GroupName="SearchGroup"
                                 Content="{Tr 'PAS4U.SearchSelectionWindow.Package', DefaultText='Package ID'}"
                                 IsChecked="True"
                                 Command="{Binding RadioSearchCheckedCommand}"
                                 CommandParameter="Package"
                                 Margin="0 0 20 0"/>
                    <RadioButton GroupName="SearchGroup"
                                 Content="{Tr 'PAS4U.SearchSelectionWindow.Name', DefaultText='Sender Name'}"
                                 Command="{Binding RadioSearchCheckedCommand}"
                                 CommandParameter="Name"/>
                </StackPanel>
                <!-- ARCHIVE CHECKBOX -->
                <CheckBox Content="{Tr 'PAS4U.SearchSelectionWindow.Archive', DefaultText='Archive?'}"
                          Grid.Row="4" Grid.ColumnSpan="2"
                          HorizontalAlignment="Center"
                          IsChecked="{Binding ArchiveChecked, Mode=TwoWay}"
                          Margin="0 5 0 10"/>
                <!-- SEARCH BUTTON -->
                <Button Content="{Tr 'PAS4U.SearchSelectionWindow.Search', DefaultText='Search'}"
                        Grid.Row="5" Grid.ColumnSpan="2"
                        Command="{Binding SearchCommand}"
                        IsEnabled="{Binding SearchButtonEnabled}"
                        Style="{StaticResource SmallAccentButtonYellow}"
                        Width="120"
                        HorizontalAlignment="Center"
                        Margin="0 10 0 0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
