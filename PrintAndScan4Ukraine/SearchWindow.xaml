<Window x:Class="PrintAndScan4Ukraine.SearchWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:local="clr-namespace:PrintAndScan4Ukraine"
        mc:Ignorable="d"
        Title="Search Results"
        Height="420" Width="600"
        Background="{StaticResource PageBackground}"
        WindowStartupLocation="CenterScreen"
        Icon="/barcode.png">
    <Grid>
        <!-- MAIN CARD -->
        <Border Style="{StaticResource Card}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="25"
                Width="520"
                Margin="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- HEADER TEXT -->
                <TextBlock Text="{Binding TopText}"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource HeaderText}"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 10"/>
                <!-- BLUE ACCENT BAR -->
                <Border Background="{StaticResource UA_Blue}"
                        Grid.Row="1"
                        Height="6"
                        Width="140"
                        CornerRadius="3"
                        HorizontalAlignment="Center"
                        Margin="0 0 0 15"/>
                <!-- LISTVIEW -->
                <ListView x:Name="LstItems"
                          Grid.Row="2"
                          Margin="0 0 0 10"
                          ItemsSource="{Binding PreviousShipments}"
                          SelectedItem="{Binding SelectedShipment, Mode=TwoWay}"
                          BorderThickness="0"
                          Background="#FAFAFA">
                    <!-- ITEM STYLE -->
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Margin" Value="0 4"/>
                            <Setter Property="Padding" Value="8"/>
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="BorderBrush" Value="#D1D5DB"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6">
                                            <ContentPresenter Margin="4"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource UA_Blue}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource UA_Yellow}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <!-- ITEM TEMPLATE -->
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="{Binding PackageId}"
                                           FontStyle="Italic"
                                           FontSize="12"
                                           Foreground="#374151"/>
                                <TextBlock Text="{Binding Recipient_Name}"
                                           Grid.Row="1"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           Foreground="#1F2937"/>
                                <TextBlock Text="{Binding Sender_Phone}"
                                           Grid.Row="2"
                                           FontWeight="Bold"
                                           FontSize="12"
                                           Foreground="#1F2937"/>
                                <TextBlock Text="{Binding Recipient_Address}"
                                           Grid.Row="3"
                                           TextWrapping="Wrap"
                                           Foreground="#374151"/>
                                <TextBlock Text="{Binding Statuses}"
                                           Grid.Row="4"
                                           Foreground="#374151"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <!-- CLOSE BUTTON -->
                <Button Grid.Row="3"
                        Content="Close"
                        Command="{Binding CloseCommand}"
                        Style="{StaticResource AccentButtonYellow}"
                        Width="120"
                        HorizontalAlignment="Center"
                        Margin="0 10 0 0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
